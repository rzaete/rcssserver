{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Build and Launch rcssserver",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/rcssserver",
      "args": ["server::synch_mode=on", "server::profile=on"],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "preLaunchTask": "build rcssserver",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
